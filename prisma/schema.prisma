// ImageAI Studio - Database Schema
// Plataforma SaaS de generación de imágenes con IA

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Planes de suscripción disponibles
enum Plan {
  FREE
  PRO
  BUSINESS
}

// Usuarios de la plataforma
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  image         String?
  password      String?   // Hash bcrypt para auth local
  
  // Plan y créditos
  plan          Plan      @default(FREE)
  credits       Int       @default(5)    // Créditos disponibles
  creditsUsed   Int       @default(0)    // Créditos usados hoy
  lastReset     DateTime  @default(now()) // Último reset de créditos diarios
  
  // Stripe
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?   @unique
  stripePriceId        String?
  stripeCurrentPeriodEnd DateTime?
  
  // Relaciones
  images        Image[]
  activities    Activity[]
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// Imágenes generadas
model Image {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  prompt      String              // Prompt original
  enhancedPrompt String?          // Prompt mejorado por IA
  imageBase64 String?             // Imagen en base64
  imageSize   String              // "1024x1024", "768x1344", etc.
  style       String?             // Estilo aplicado
  
  isPublic    Boolean  @default(false)
  likes       Int      @default(0)
  
  createdAt   DateTime @default(now())
}

// Historial de actividades
model Activity {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  type        String   // "generate", "upgrade", "purchase"
  description String
  credits     Int      // Créditos usados/ganados
  
  createdAt   DateTime @default(now())
}

// Configuración de planes (para fácil modificación)
model PlanConfig {
  id          String   @id @default(cuid())
  plan        Plan     @unique
  name        String
  price       Float    // Precio mensual
  credits     Int      // Créditos por día
  features    String   // JSON array de características
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
